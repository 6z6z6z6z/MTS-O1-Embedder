{
  "experiment_name": "natops_v2_improved",
  "mode": "train",
  "data": {
    "data_path": "mts_agent/data/processed/natops_train.jsonl",
    "raw_data_path": "mts_agent/NATOPS",
    "dataset_name": "natops",
    "batch_size": 30,
    "ts_dim": 24,
    "augment": true,
    "max_length": 512,
    "domain_info": "Motion capture recording of a pilot performing an aviation hand gesture. 24 channels (8 body locations × 3D). 6 gesture classes."
  },
  "model": {
    "llm_path": "local_model",
    "ts_input_dim": 24,
    "ts_hidden_dim": 128,
    "encoder_base_channels": 64,
    "encoder_target_tokens": 16,
    "encoder_dropout": 0.1,
    "encoder_norm": "group",
    "embedding_pooling": "mean",
    "tuning_strategy": "lora",
    "num_trainable_layers": 2
  },
  "training": {
    "seed": 42,
    "epochs": 30,
    "lr": 1e-4,
    "contrastive_temperature": 0.1,
    "alignment_text_mode": "full",
    "contrastive_positive_mode": "label",
    "gradient_accumulation_steps": 1,
    "balanced_sampling": true,
    "classes_per_batch": 6,
    "samples_per_class": 5,
    "early_stopping_patience": 8,
    "early_stopping_min_delta": 0.001,
    "training_stage": "alignment",
    "contrastive_weight": 1.0,
    "lm_weight": 0.0,
    "cls_weight": 0.3,
    "memory_bank_size": 144,
    "use_amp": true,
    "save_dir": "checkpoints_natops_v2",
    "ckpt_path": null,
    "retrieval_eval_enabled": true,
    "retrieval_eval_k": 5,
    "retrieval_eval_alpha": 0.9,
    "retrieval_eval_vote_strategy": "weighted",
    "retrieval_eval_interval": 1
  },
  "retrieval": {
    "k": 5,
    "alpha": 0.9,
    "dtw_window_size": null,
    "fast_dtw_max_len": 100
  },
  "inference": {
    "max_new_tokens": 200,
    "temperature": 0.7,
    "do_sample": false,
    "use_api": false,
    "api_key": null
  },
  "environment": {
    "disable_ssl_verify": false,
    "force_offline": true,
    "use_dummy_tokenizer": false,
    "device": "cuda"
  },
  "arm": {
    "enabled": false
  }
}
