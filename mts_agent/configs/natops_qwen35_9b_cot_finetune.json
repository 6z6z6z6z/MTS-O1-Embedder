{
  "experiment_name": "natops_qwen35_9b_cot_finetune",
  "mode": "train",
  "data": {
    "data_path": "mts_agent/data/processed/natops_train.jsonl",
    "raw_data_path": "mts_agent/NATOPS",
    "dataset_name": "natops",
    "batch_size": 6,
    "ts_dim": 24,
    "augment": true,
    "max_length": 128,
    "domain_info": "Motion capture recording of a pilot performing an aviation hand gesture. 24 channels (8 body locations x 3D). 6 gesture classes."
  },
  "model": {
    "llm_path": "local_model/Qwen/Qwen3___5-4B",
    "ts_input_dim": 24,
    "ts_hidden_dim": 128,
    "output_dim": 1024,
    "encoder_base_channels": 64,
    "encoder_target_tokens": 16,
    "encoder_dropout": 0.1,
    "encoder_norm": "group",
    "embedding_pooling": "last",
    "llm_attn_implementation": "eager",
    "tuning_strategy": "lora",
    "num_trainable_layers": 2,
    "stem_strides": [5, 5],
    "patch_size": 5
  },
  "training": {
    "seed": 42,
    "epochs": 30,
    "lr": 2e-5,
    "contrastive_temperature": 0.1,
    "alignment_text_mode": "full",
    "contrastive_positive_mode": "label",
    "gradient_accumulation_steps": 32,
    "balanced_sampling": true,
    "classes_per_batch": 3,
    "samples_per_class": 2,
    "allow_repeated_classes_in_batch": true,
    "early_stopping_patience": 8,
    "early_stopping_min_delta": 0.001,
    "training_stage": "alignment",
    "contrastive_weight": 1.0,
    "lm_weight": 0.0,
    "cls_weight": 0.2,
    "ts_only_embedding": false,
    "retrieval_eval_enabled": true,
    "retrieval_eval_k": 5,
    "retrieval_eval_alpha": 0.9,
    "retrieval_eval_vote_strategy": "weighted",
    "retrieval_eval_interval": 1,
    "use_amp": true,
    "amp_dtype": "bf16",
    "save_dir": "checkpoints_natops_qwen35_9b",
    "memory_bank_size": 36,
    "auto_two_stage": false
  },
  "retrieval": {
    "k": 5,
    "alpha": 0.9,
    "dtw_window_size": null,
    "fast_dtw_max_len": 100
  },
  "inference": {
    "max_new_tokens": 200,
    "temperature": 0.7,
    "do_sample": false,
    "use_api": false,
    "api_key": null
  },
  "environment": {
    "disable_ssl_verify": false,
    "force_offline": true,
    "use_dummy_tokenizer": false,
    "device": "cuda"
  },
  "arm": {
    "enabled": false,
    "k": 5,
    "epochs": 100,
    "lr": 0.0003,
    "num_heads": 8,
    "dropout": 0.1,
    "augment_gallery": false,
    "augment_factor": 5
  }
}
