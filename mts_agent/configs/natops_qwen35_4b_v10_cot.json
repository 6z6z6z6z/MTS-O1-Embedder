{
  "experiment_name": "natops_qwen35_4b_v10_cot",
  "mode": "train",
  "data": {
    "data_path": "mts_agent/data/processed/natops_train.jsonl",
    "raw_data_path": "mts_agent/NATOPS",
    "dataset_name": "natops",
    "batch_size": 18,
    "ts_dim": 24,
    "augment": true,
    "max_length": 512,
    "domain_info": "Motion capture recording of a pilot performing an aviation hand gesture. 24 channels (8 body locations x 3D). 6 gesture classes."
  },
  "model": {
    "llm_path": "local_model/Qwen/Qwen3___5-4B",
    "ts_input_dim": 24,
    "ts_hidden_dim": 128,
    "output_dim": 1024,
    "encoder_base_channels": 64,
    "encoder_dropout": 0.1,
    "encoder_norm": "group",
    "embedding_pooling": "last",
    "llm_attn_implementation": "eager",
    "tuning_strategy": "lora",
    "num_trainable_layers": 2,
    "stem_strides": [2],
    "patch_size": 5,
    "encoder_type": "cnn"
  },
  "training": {
    "seed": 42,
    "epochs": 40,
    "lr": 1e-4,
    "weight_decay": 0.01,
    "warmup_epochs": 3,
    "contrastive_temperature": 0.5,
    "learnable_temperature": true,
    "softclt_enabled": true,
    "softclt_sigma": 1.0,
    "alignment_text_mode": "full",
    "contrastive_positive_mode": "label",
    "gradient_accumulation_steps": 1,
    "max_grad_norm": 1.0,
    "balanced_sampling": true,
    "classes_per_batch": 6,
    "samples_per_class": 3,
    "allow_repeated_classes_in_batch": true,
    "early_stopping_patience": 12,
    "early_stopping_min_delta": 0.005,
    "training_stage": "alignment",
    "contrastive_weight": 1.0,
    "lm_weight": 0.0,
    "cls_weight": 0.0,
    "ts_only_embedding": false,
    "retrieval_eval_enabled": true,
    "retrieval_eval_k": 5,
    "retrieval_eval_alpha": 0.9,
    "retrieval_eval_vote_strategy": "weighted",
    "retrieval_eval_interval": 1,
    "use_amp": true,
    "amp_dtype": "bf16",
    "save_dir": "checkpoints_natops_v10_cot",
    "memory_bank_size": 90,
    "auto_two_stage": false,
    "ema_momentum": 0.99,
    "proto_weight": 0.1,
    "proto_momentum": 0.9,
    "loo_smoothing_window": 3
  },
  "retrieval": {
    "k": 5,
    "alpha": 0.9,
    "dtw_window_size": null,
    "fast_dtw_max_len": 100
  },
  "inference": {
    "max_new_tokens": 200,
    "temperature": 0.7,
    "do_sample": false,
    "use_api": false,
    "api_key": null
  },
  "environment": {
    "disable_ssl_verify": false,
    "force_offline": true,
    "use_dummy_tokenizer": false,
    "device": "cuda"
  }
}
